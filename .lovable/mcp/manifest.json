  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://xllpedrhhzoljkfvkgef.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "agrosight-mcp",
      "version": "0.1.0",
      "title": "AgroSight MCP"
    },
    "tools": [
      {
        "name": "list_crop_predictions",
        "title": "List crop predictions",
        "description": "List the signed-in user's saved crop yield predictions.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "Max predictions to return."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_farm_finances",
        "title": "List farm finances",
        "description": "List the signed-in user's farm finance records (expenses, expected revenue, profit/loss).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 10,
              "description": "Max records to return."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_mandi_prices",
        "title": "Get mandi prices",
        "description": "Fetch latest Indian mandi (market) prices, optionally filtered by commodity or state.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": true
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "commodity": {
              "type": "string",
              "minLength": 1,
              "description": "Optional commodity filter, e.g. 'Rice'."
            },
            "state": {
              "type": "string",
              "minLength": 1,
              "description": "Optional state filter, e.g. 'Telangana'."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 50,
              "default": 20,
              "description": "Max rows to return."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
